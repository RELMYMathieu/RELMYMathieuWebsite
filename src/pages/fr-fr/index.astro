---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
import SocialLinks from '../../components/SocialLinks.astro';
import Works from '../../components/Works.astro';
import { Image } from 'astro:assets';
import vulkanTriangle from '../../images/vulkan-triangle.png';

const birthday = new Date('2008-09-03');
const now = new Date();
let age = now.getFullYear() - birthday.getFullYear();
if (
  now.getMonth() < birthday.getMonth() ||
  (now.getMonth() === birthday.getMonth() && now.getDate() < birthday.getDate())
) age--;

const birthdayFormatted = '3 septembre 2008';
---

<Layout title="Accueil" description="Site personnel de Relmy Mathieu — futur ingénieur nucléaire, dev, nerd.">
  <Section delay={0}>
    <h1 class="text-4xl font-bold mb-1">Relmy Mathieu</h1>
    <p class="text-muted">Futur Ingénieur Nucléaire, Dev, Nerd</p>
    <SocialLinks />
  </Section>

  <Section delay={0.07}>
    <h2 class="font-bold mb-2 text-sm uppercase tracking-widest text-subtle">Fun facts sur moi</h2>
    <p>☕ J'aime beaucoup le café (*^▽^*)</p>
    <p>🐱 J'aime aussi les chats</p>
    <h2 class="font-bold mt-4 mb-2 text-sm uppercase tracking-widest text-subtle">D'où je viens & langues parlées</h2>
    <p>🇫🇷 Français!</p>
    <p>
      <span class="dashed-hint" tabindex="0" data-tip="Pour l'anglais : j'y travaille — un diplôme officiel est prévu, pour un jour... Peut-être.">
        Je parle couramment le français et l'anglais (🇫🇷 / 🇬🇧)
      </span>
    </p>
    <p class="text-sm leading-relaxed mt-4">
      J'apprends également l'Italien (🇮🇹) et le Russe (🇷🇺) — je peux me débrouiller avec les deux, mais je ne suis pas encore fluent.
    </p>
    <h2 class="font-bold mt-4 mb-2 text-sm uppercase tracking-widest text-subtle">Mon âge</h2>
    <p class="mt-2">
      <span class="dashed-hint" tabindex="0" aria-label={`Né le ${birthdayFormatted}`} data-tip={`Né le ${birthdayFormatted} ;)`}>
        {age} ans
      </span>
    </p>
  </Section>

  <Section delay={0.14}>
    <h2 class="font-bold mb-2 text-sm uppercase tracking-widest text-subtle">Développement, de jeux, et autres applications (hobbies)</h2>
    <p class="text-sm leading-relaxed">
      Je développe des jeux. Je travaille sur mon propre
      <button
        class="dashed-hint"
        id="engine-trigger"
        type="button"
        aria-haspopup="dialog"
        aria-controls="engine-lightbox"
        data-tip="clique pour jeter un œil 👀"
      >moteur de jeu</button>
      (privé pour l'instant) et j'ai travaillé sur quelques jeux dans divers moteurs au fil du temps.
      Pendant mon temps libre, j'aime aussi créer des pages web — c'est un peu
      pour ça que ce site existe. J'ai notamment crée un petit site ou deux pour
      des projets de lycée, parce que pourquoi pas. C'est un bon moyen d'apprendre et de s'amuser avec le développement
      web et de s'exprimer, même si ce n'est pas mon domaine principal d'intérêt.
    </p>
    <p class="text-sm leading-relaxed mt-4">
      Plus généralement, j'aime coder dans mon temps libre, que ce soit un petit
      script d'automatisation, un jeu, un site pour un ami, un projet scolaire, ou
      juste pour le plaisir. Coder est une façon créative de passer le temps.
      J'espère que mon futur métier y laissera une place. Qui n'a jamais ouvert un
      grand projet open source juste pour lire le code, par curiosité ?
    </p>
  </Section>

  <Section delay={0.2}>
    <h2 class="font-bold mb-2 text-sm uppercase tracking-widest text-subtle">Ingénierie Nucléaire</h2>
    <p class="text-sm leading-relaxed">
      J'ai une vraie passion pour l'ingénierie nucléaire — les réacteurs, leur
      physique, tout ça. J'ai un jeu, un peu comme un projet secondaire sur lequel
      je reviens par moments dessus, il est en cours de développement, mais
      je n'ai pas encore eu le temps d'y consacrer beaucoup d'efforts. J'en
      parlerai peut-être dans un article de blog un jour, si l'idée m'en
      vient, mais pour l'instant, c'est un projet personnel que je garde un peu
      pour moi.
    </p>
  </Section>

  <Works />
</Layout>

<dialog id="engine-lightbox" class="lightbox" aria-labelledby="engine-lightbox-title" aria-describedby="engine-lightbox-caption">
  <div class="lightbox-inner">
    <div class="lightbox-controls">
      <h2 id="engine-lightbox-title" class="lightbox-title">Aperçu du moteur</h2>
      <button id="engine-close" class="lightbox-close" type="button" aria-label="Fermer l'aperçu">Fermer</button>
    </div>
    <Image src={vulkanTriangle} alt="Premier triangle Vulkan" class="lightbox-img" />
    <p id="engine-lightbox-caption" class="lightbox-caption">yaay premier triangle en vulkan. (31 mars 2026)</p>
  </div>
</dialog>

<style>
  /* ── Hint tooltips ── */

  .dashed-hint {
    position: relative;
    cursor: help;
    text-decoration: underline dashed var(--hint-border);
    text-underline-offset: 3px;
    background: none;
    font: inherit;
    color: inherit;
    padding: 0;
  }

  button.dashed-hint {
    display: inline;
    cursor: pointer;
  }

  .dashed-hint::after {
    content: attr(data-tip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 0;
    background: var(--hint-bg);
    color: var(--hint-fg);
    font-size: 0.75rem;
    padding: 4px 8px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
    z-index: 10;
  }

  .dashed-hint:hover::after,
  .dashed-hint:focus-visible::after { opacity: 1; }

  .dashed-hint:focus-visible,
  .lightbox-close:focus-visible {
    outline: 2px dashed currentColor;
    outline-offset: 3px;
  }

  /* ── Lightbox ── */

  .lightbox {
    border: none;
    background: transparent;
    padding: 0;
    margin: auto;
    opacity: 0;
    transform: scale(0.95);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      display 0.2s allow-discrete,
      overlay 0.2s allow-discrete;
  }

  .lightbox[open] {
    opacity: 1;
    transform: scale(1);
  }

  @starting-style {
    .lightbox[open] {
      opacity: 0;
      transform: scale(0.95);
    }
  }

  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0);
    transition:
      background 0.2s ease,
      display 0.2s allow-discrete,
      overlay 0.2s allow-discrete;
  }

  .lightbox[open]::backdrop {
    background: rgba(0, 0, 0, 0.85);
  }

  @starting-style {
    .lightbox[open]::backdrop {
      background: rgba(0, 0, 0, 0);
    }
  }

  .lightbox-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    cursor: default;
    padding: 0.5rem;
  }

  .lightbox-controls {
    width: min(640px, 90vw);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .lightbox-title {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--lightbox-caption);
  }

  .lightbox-close {
    border: 1px solid currentColor;
    background: transparent;
    color: var(--lightbox-caption);
    font: inherit;
    font-size: 0.75rem;
    text-transform: uppercase;
    padding: 0.45rem 0.75rem;
    min-height: 2.75rem;
    cursor: pointer;
  }

  .lightbox-img {
    max-width: min(640px, 90vw);
    max-height: 75vh;
    object-fit: contain;
    border: 1px solid var(--lightbox-img-border);
  }

  .lightbox-caption {
    color: var(--lightbox-caption);
    font-family: monospace;
    font-size: 0.75rem;
  }

  @media (max-width: 640px) {
    .lightbox-controls {
      flex-direction: column;
      align-items: flex-start;
    }

    .dashed-hint::after {
      white-space: normal;
      max-width: min(15rem, 80vw);
    }
  }
</style>

<!-- Motion.dev fade-in animations (extracted) -->
<script>
  import '../../scripts/fade-in';
</script>

<!-- Lightbox script -->
<script>
  function initLightbox() {
    const trigger = document.getElementById('engine-trigger') as HTMLButtonElement | null;
    const lightbox = document.getElementById('engine-lightbox') as HTMLDialogElement;
    const closeBtn = document.getElementById('engine-close') as HTMLButtonElement | null;
    if (!trigger || !lightbox || !closeBtn) return;

    if (trigger.dataset.bound === 'true') return;
    trigger.dataset.bound = 'true';

    const openDialog = () => {
      lightbox.showModal();
      closeBtn.focus();
    };

    const closeDialog = () => {
      lightbox.close();
      trigger.focus();
    };

    trigger.addEventListener('click', openDialog);
    closeBtn.addEventListener('click', closeDialog);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeDialog();
    });

    lightbox.addEventListener('close', () => {
      if (document.activeElement !== trigger) trigger.focus();
    });
  }

  initLightbox();
  document.addEventListener('astro:page-load', initLightbox);
</script>
