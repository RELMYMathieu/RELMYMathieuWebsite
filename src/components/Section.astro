---
interface Props {
  class?: string;
  dashed?: boolean;
  delay?: number;
}

const { class: className, dashed = false, delay = 0 } = Astro.props;
---

<section
  class:list={[
    'section-card',
    dashed && 'section-card--dashed',
    className,
  ]}
  data-fade-in
  data-fade-delay={delay}
>
  <slot />
</section>

<style>
  .section-card {
    position: relative;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    transition: border-color 0.22s ease;
    isolation: isolate;
  }

  .section-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.04), transparent 65%);
    opacity: 0;
    pointer-events: none;
    z-index: -1;
    transition: opacity 0.24s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .section-card:hover {
    border-color: var(--border-hover);
  }

  .section-card:hover::before {
    opacity: 1;
  }

  .section-card--dashed {
    border-style: dashed;
  }
</style>
