---
import Layout from '../../../layouts/Layout.astro';
import Section from '../../../components/Section.astro';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('fr-fr');
---

<Layout title={t('blog.title')} description="Le blog de Relmy Mathieu, pensées, notes, bref.">
  <Section delay={0}>
    <h1 class="text-2xl font-bold mb-1">{t('blog.title')}</h1>
    <p class="text-subtle text-sm">{t('blog.subtitle')}</p>
  </Section>

  <Section dashed delay={0.07}>
    <p class="text-sm text-subtle">{t('blog.empty')}</p>
  </Section>
</Layout>
