---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');
---

<Layout title={t('blog.title')}>
  <Section delay={0}>
    <h1 class="text-2xl font-bold mb-1">{t('blog.title')}</h1>
    <p class="text-subtle text-sm">{t('blog.subtitle')}</p>
  </Section>

  <Section dashed delay={0.07}>
    <p class="text-sm text-subtle">{t('blog.empty')}</p>
  </Section>
</Layout>
