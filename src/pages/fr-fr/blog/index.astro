---
import Layout from '../../../layouts/Layout.astro';
import Section from '../../../components/Section.astro';
---

<Layout title="Blog" description="Le blog de Relmy Mathieu — pensées, notes, bref.">
  <Section delay={0}>
    <h1 class="text-2xl font-bold mb-1">Blog</h1>
    <p class="text-gray-500 dark:text-gray-400 text-sm">pensées, notes, bref.</p>
  </Section>

  <Section dashed delay={0.07}>
    <p class="text-sm text-gray-500 dark:text-gray-400">
      Bonjour, cher blog ! Aucun post pour l'instant — revenez plus tard.
    </p>
  </Section>
</Layout>
