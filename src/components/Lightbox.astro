---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  id: string;
  triggerId: string;
  title: string;
  caption: string;
  closeLabel: string;
  image: ImageMetadata;
  imageAlt: string;
}

const { id, triggerId, title, caption, closeLabel, image, imageAlt } = Astro.props;
---

<dialog
  id={id}
  class="lightbox"
  aria-labelledby={`${id}-title`}
  aria-describedby={`${id}-caption`}
>
  <div class="lightbox-inner">
    <div class="lightbox-controls">
      <h2 id={`${id}-title`} class="lightbox-title">{title}</h2>
      <button class="lightbox-close" type="button" aria-label={closeLabel} data-lightbox-close>Close</button>
    </div>
    <Image src={image} alt={imageAlt} class="lightbox-img" />
    <p id={`${id}-caption`} class="lightbox-caption">{caption}</p>
  </div>
</dialog>

<script define:vars={{ id, triggerId }}>
  function initLightbox() {
    const trigger = document.getElementById(triggerId);
    const lightbox = document.getElementById(id);
    const closeBtn = lightbox?.querySelector('[data-lightbox-close]');
    if (!trigger || !lightbox || !closeBtn) return;

    if (trigger.dataset.bound === 'true') return;
    trigger.dataset.bound = 'true';

    const openDialog = () => {
      lightbox.showModal();
      closeBtn.focus();
    };

    const closeDialog = () => {
      lightbox.close();
      trigger.focus();
    };

    trigger.addEventListener('click', openDialog);
    closeBtn.addEventListener('click', closeDialog);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeDialog();
    });

    lightbox.addEventListener('close', () => {
      if (document.activeElement !== trigger) trigger.focus();
    });
  }

  initLightbox();
  document.addEventListener('astro:page-load', initLightbox);
</script>

<style>
  .lightbox {
    border: none;
    background: transparent;
    padding: 0;
    margin: auto;
    opacity: 0;
    transform: scale(0.95);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      display 0.2s allow-discrete,
      overlay 0.2s allow-discrete;
  }

  .lightbox[open] {
    opacity: 1;
    transform: scale(1);
  }

  @starting-style {
    .lightbox[open] {
      opacity: 0;
      transform: scale(0.95);
    }
  }

  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0);
    transition:
      background 0.2s ease,
      display 0.2s allow-discrete,
      overlay 0.2s allow-discrete;
  }

  .lightbox[open]::backdrop {
    background: rgba(0, 0, 0, 0.85);
  }

  @starting-style {
    .lightbox[open]::backdrop {
      background: rgba(0, 0, 0, 0);
    }
  }

  .lightbox-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    cursor: default;
    padding: 0.5rem;
  }

  .lightbox-controls {
    width: min(640px, 90vw);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .lightbox-title {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--lightbox-caption);
  }

  .lightbox-close {
    border: 1px solid currentColor;
    background: transparent;
    color: var(--lightbox-caption);
    font: inherit;
    font-size: 0.75rem;
    text-transform: uppercase;
    padding: 0.45rem 0.75rem;
    min-height: 2.75rem;
    cursor: pointer;
  }

  .lightbox-close:focus-visible {
    outline: 2px dashed currentColor;
    outline-offset: 3px;
  }

  .lightbox-img {
    max-width: min(640px, 90vw);
    max-height: 75vh;
    object-fit: contain;
    border: 1px solid var(--lightbox-img-border);
  }

  .lightbox-caption {
    color: var(--lightbox-caption);
    font-family: monospace;
    font-size: 0.75rem;
  }

  @media (max-width: 640px) {
    .lightbox-controls {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
