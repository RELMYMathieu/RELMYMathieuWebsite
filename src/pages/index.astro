---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Works from '../components/Works.astro';
import { Image } from 'astro:assets';
import vulkanTriangle from '../images/vulkan-triangle.png';

const birthday = new Date('2008-09-03');
const now = new Date();
let age = now.getFullYear() - birthday.getFullYear();
if (
  now.getMonth() < birthday.getMonth() ||
  (now.getMonth() === birthday.getMonth() && now.getDate() < birthday.getDate())
) age--;

const birthdayFormatted = 'September 3, 2008';
---

<Layout title="Home">
  <!-- Name -->
  <Section delay={0}>
    <h1 class="text-4xl font-bold mb-1">Relmy Mathieu</h1>
    <p class="text-gray-600 dark:text-gray-400">Aspiring Nuclear Engineer, Dev, Nerd</p>
    <SocialLinks />
  </Section>

  <!-- Quick facts -->
  <Section delay={0.07}>
    <h2 class="font-bold mb-2 text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400">Fun facts about myself</h2>
    <p>☕ I love coffee</p>
    <p>🐱 I also love cats</p>
    <h2 class="font-bold mt-4 mb-2 text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400">Where I'm from & languages spoken</h2>
    <p>🇫🇷 I'm French</p>
    <p>
      <span class="dashed-hint" tabindex="0" data-tip="Working on getting a proper diploma for it!">
        I'm bilingual (🇫🇷 / 🇬🇧)
      </span>
    </p>
    <p class="text-sm leading-relaxed mt-4">
      I'm also learning Italian (🇮🇹) and Russian (🇷🇺) — I can get by in both, but I'm not fluent yet.
    </p>
    <h2 class="font-bold mt-4 mb-2 text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400">My age</h2>
    <p class="mt-2">
      <span class="dashed-hint" tabindex="0" aria-label={`Born ${birthdayFormatted}`} data-tip={`Born ${birthdayFormatted} ;)`}>
        I'm {age} years old
      </span>
    </p>
  </Section>

  <!-- Games & code -->
  <Section delay={0.14}>
    <h2 class="font-bold mb-2 text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400">Making games & code (a hobby)</h2>
    <p class="text-sm leading-relaxed">
      I code games. I'm working on my own
      <button
        class="dashed-hint"
        id="engine-trigger"
        type="button"
        aria-haspopup="dialog"
        aria-controls="engine-lightbox"
        data-tip="click to peek 👀"
      >game engine</button>
      (private for now) and have worked on
      a few games along the way. In my free time I also enjoy building web pages, which
      is kind of how this site exists.
    </p>
    <p class="text-sm leading-relaxed mt-4">
      Furthermore, I also enjoy coding in my spare time, whether it's a small automation script,
      a game (seen earlier), a website for a friend, for a school project, or just tinkering with some code for fun.
      Coding is a fun way to pass time and to be creative. I like it a lot and I hope that my job will incorporate coding in some way.
      Who doesn't just open a big open source repo to read through the code and understand how it works, right?
    </p>
  </Section>

  <!-- Nuclear engineering -->
  <Section delay={0.2}>
    <h2 class="font-bold mb-2 text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400">Nuclear Engineering</h2>
    <p class="text-sm leading-relaxed">
      I have a burning passion for nuclear engineering — reactors, their physics, the whole
      thing. I've got a nuclear engineering related game that's on the stove, but I haven't
      gotten the time to work on it much yet. Maybe I'll share more about it in the future,
      on a blog post or something.
    </p>
  </Section>

  <!-- Works -->
  <Works />
</Layout>

<!-- Engine preview lightbox -->
<dialog id="engine-lightbox" class="lightbox" aria-labelledby="engine-lightbox-title" aria-describedby="engine-lightbox-caption">
  <div class="lightbox-inner">
    <div class="lightbox-controls">
      <h2 id="engine-lightbox-title" class="lightbox-title">Game engine preview</h2>
      <button id="engine-close" class="lightbox-close" type="button" aria-label="Close preview">Close</button>
    </div>
    <Image src={vulkanTriangle} alt="First Vulkan triangle" class="lightbox-img" />
    <p id="engine-lightbox-caption" class="lightbox-caption">yaay first triangle in vulkan. (March 31st, 2026)</p>
  </div>
</dialog>

<style>
  /* ── Hint tooltips ── */

  .dashed-hint {
    position: relative;
    cursor: help;
    text-decoration: underline dashed var(--hint-border);
    text-underline-offset: 3px;
    background: none;
    font: inherit;
    color: inherit;
    padding: 0;
  }

  button.dashed-hint {
    display: inline;
    cursor: pointer;
  }

  .dashed-hint::after {
    content: attr(data-tip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 0;
    background: var(--hint-bg);
    color: var(--hint-fg);
    font-size: 0.75rem;
    padding: 4px 8px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
    z-index: 10;
  }

  .dashed-hint:hover::after,
  .dashed-hint:focus-visible::after { opacity: 1; }

  .dashed-hint:focus-visible,
  .lightbox-close:focus-visible {
    outline: 2px dashed currentColor;
    outline-offset: 3px;
  }

  /* ── Lightbox ── */

  .lightbox {
    border: none;
    background: transparent;
    padding: 0;
    margin: auto;
    opacity: 0;
    transform: scale(0.95);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      display 0.2s allow-discrete,
      overlay 0.2s allow-discrete;
  }

  .lightbox[open] {
    opacity: 1;
    transform: scale(1);
  }

  @starting-style {
    .lightbox[open] {
      opacity: 0;
      transform: scale(0.95);
    }
  }

  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0);
    transition:
      background 0.2s ease,
      display 0.2s allow-discrete,
      overlay 0.2s allow-discrete;
  }

  .lightbox[open]::backdrop {
    background: rgba(0, 0, 0, 0.85);
  }

  @starting-style {
    .lightbox[open]::backdrop {
      background: rgba(0, 0, 0, 0);
    }
  }

  .lightbox-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    cursor: default;
    padding: 0.5rem;
  }

  .lightbox-controls {
    width: min(640px, 90vw);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .lightbox-title {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--lightbox-caption);
  }

  .lightbox-close {
    border: 1px solid currentColor;
    background: transparent;
    color: var(--lightbox-caption);
    font: inherit;
    font-size: 0.75rem;
    text-transform: uppercase;
    padding: 0.45rem 0.75rem;
    min-height: 2.75rem;
    cursor: pointer;
  }

  .lightbox-img {
    max-width: min(640px, 90vw);
    max-height: 75vh;
    object-fit: contain;
    border: 1px solid var(--lightbox-img-border);
  }

  .lightbox-caption {
    color: var(--lightbox-caption);
    font-family: monospace;
    font-size: 0.75rem;
  }

  @media (max-width: 640px) {
    .lightbox-controls {
      flex-direction: column;
      align-items: flex-start;
    }

    .dashed-hint::after {
      white-space: normal;
      max-width: min(15rem, 80vw);
    }
  }
</style>

<!-- Motion.dev fade-in animations (extracted) -->
<script>
  import '../scripts/fade-in';
</script>

<!-- Lightbox script -->
<script>
  function initLightbox() {
    const trigger = document.getElementById('engine-trigger') as HTMLButtonElement | null;
    const lightbox = document.getElementById('engine-lightbox') as HTMLDialogElement;
    const closeBtn = document.getElementById('engine-close') as HTMLButtonElement | null;
    if (!trigger || !lightbox || !closeBtn) return;

    if (trigger.dataset.bound === 'true') return;
    trigger.dataset.bound = 'true';

    const openDialog = () => {
      lightbox.showModal();
      closeBtn.focus();
    };

    const closeDialog = () => {
      lightbox.close();
      trigger.focus();
    };

    trigger.addEventListener('click', openDialog);
    closeBtn.addEventListener('click', closeDialog);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeDialog();
    });

    lightbox.addEventListener('close', () => {
      if (document.activeElement !== trigger) trigger.focus();
    });
  }

  initLightbox();
  document.addEventListener('astro:page-load', initLightbox);
</script>
