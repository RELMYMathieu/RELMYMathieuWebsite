---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { getLangFromUrl, useTranslations, useTranslatedPath, getRawPath } from '../i18n/utils';
import { LOCALES, getLocale } from '../i18n/config';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Relmy Mathieu's personal site — aspiring nuclear engineer, dev, nerd.",
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const rawPath = getRawPath(Astro.url, lang);
const langLinks = LOCALES.map((l) => ({
  ...l,
  href: useTranslatedPath(l.code)(rawPath),
  active: l.code === lang,
}));

const currentLocale = getLocale(lang);
const htmlLang = currentLocale.htmlLang;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />

    <title>{title} - Relmy Mathieu</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={`${title} — Relmy Mathieu`} />
    <meta property="og:description" content={description} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} — Relmy Mathieu`} />
    <meta name="twitter:description" content={description} />

    <ClientRouter />
    <script is:inline>
      (function () {
        const storedTheme = localStorage.getItem('theme');
        const dark = storedTheme
          ? storedTheme === 'dark'
          : window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.classList.toggle('dark', dark);
      })();

      document.addEventListener('astro:before-swap', (e) => {
        e.newDocument.documentElement.classList.toggle(
          'dark',
          document.documentElement.classList.contains('dark')
        );
      });
    </script>
  </head>
  <body class="min-h-screen bg-white dark:bg-zinc-900 text-black dark:text-zinc-100 font-mono theme-transition">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <nav class="nav-bar">
      <a href={translatePath('/')} class="nav-link">{t('nav.home')}</a>
      <a href={translatePath('/blog')} class="nav-link">{t('nav.blog')}</a>
      <div class="ml-auto flex items-center">
        <div class="lang-dropdown" id="lang-dropdown">
          <button
            id="lang-toggle"
            type="button"
            aria-haspopup="menu"
            aria-controls="lang-menu"
            aria-expanded="false"
            aria-label="Switch language"
            class="nav-link cursor-pointer"
          >{currentLocale.short} ▾</button>
          <div class="lang-menu" id="lang-menu" hidden role="menu" aria-label="Language selector">
            {langLinks.map((l) => (
              <a
                href={l.href}
                role="menuitem"
                lang={l.htmlLang}
                class:list={['lang-option', { 'lang-option--active': l.active }]}
                aria-current={l.active ? 'page' : undefined}
              >{l.short}</a>
            ))}
          </div>
        </div>
        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle theme"
          aria-pressed="false"
          class="cursor-pointer size-11 inline-flex items-center justify-center rounded"
        ></button>
      </div>
    </nav>
    <main id="main-content" class="max-w-2xl mx-auto px-6 py-10">
      <slot />
    </main>
    <footer class="footer-bar text-subtle px-6 py-3 text-xs text-center mt-10">
      <p>{t('footer.credit')}</p>
      <p class="mt-1">(｡･∀･)ﾉﾞ</p>
    </footer>
    <script>
      import '../scripts/theme';
      import '../scripts/lang-dropdown';
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    background: var(--text-main);
    color: var(--white, #ffffff);
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    text-decoration: none;
    z-index: 100;
    transition: top 0.2s ease;
  }

  .skip-link:focus {
    top: 0;
    outline: 2px dashed currentColor;
    outline-offset: 2px;
  }

  .theme-transition {
    transition: background-color 0.25s ease, border-color 0.25s ease, color 0.25s ease;
  }

  .nav-bar {
    height: 3.5rem;
    border-bottom: 1px solid var(--border);
    padding-inline: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0;
    font-size: 0.875rem;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.75rem;
    min-height: 2.75rem;
  }

  .nav-link:hover {
    text-decoration: underline;
  }

  .lang-dropdown {
    position: relative;
  }

  .lang-menu {
    position: absolute;
    right: 0;
    top: calc(100% + 2px);
    background: var(--menu-bg);
    border: 1px solid var(--border);
    min-width: 4rem;
    z-index: 50;
    display: flex;
    flex-direction: column;
  }

  .lang-option {
    display: block;
    padding: 0.4rem 0.75rem;
    font-size: 0.875rem;
    text-align: center;
  }

  .lang-option:hover {
    text-decoration: underline;
  }

  .lang-option:focus-visible {
    outline: 2px dashed currentColor;
    outline-offset: 2px;
  }

  .lang-option--active {
    font-weight: 700;
  }

  #theme-toggle:focus-visible {
    outline: 2px dashed currentColor;
    outline-offset: 3px;
  }

  .footer-bar {
    border-top: 1px solid var(--border);
  }
</style>
