---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
---

<Layout title="Blog">
  <Section delay={0}>
    <h1 class="text-2xl font-bold mb-1">Blog</h1>
    <p class="text-subtle text-sm">thoughts, notes, whatever</p>
  </Section>

  <Section dashed delay={0.07}>
    <p class="text-sm text-subtle">
      Hello, blog! No posts yet — check back later.
    </p>
  </Section>
</Layout>
