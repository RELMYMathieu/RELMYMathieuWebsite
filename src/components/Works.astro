---
import Section from './Section.astro';
import { useTranslations, type Lang } from '../i18n/utils';
import { isLangFile, getWorkKey } from '../utils/collections';
import { getCollection, render } from 'astro:content';

interface Props {
  lang: Lang;
  delay?: number;
}

const { lang, delay = 0.2 } = Astro.props;
const t = useTranslations(lang);

const allWorks = await getCollection('works', ({ id, filePath }) => {
  return isLangFile(filePath, id, lang);
});

const works = await Promise.all(
  allWorks
    .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
    .map(async (work) => {
      const { Content } = await render(work);
      const workKey = getWorkKey(work.filePath, work.id, lang);

      return {
        id: workKey,
        name: work.data.name,
        meta: work.data.meta,
        path: work.data.path,
        links: work.data.links,
        stack: work.data.stack,
        Content,
      };
    }),
);
---

<Section delay={delay}>
  <h2 class="font-bold mb-3 text-sm uppercase tracking-widest text-subtle">{t('works.heading')}</h2>
  <ul class="works-list" role="list">
    {works.map((w) => (
      <li>
        <button
          class="work-item"
          type="button"
          data-work={w.id}
          aria-haspopup="dialog"
          aria-controls={`ww-${w.id}`}
        >
          <span class="work-item__name">{w.name}</span>
          <span class="work-item__meta">{w.meta}</span>
          <span class="work-item__open" aria-hidden="true">{t('works.open')}</span>
        </button>
      </li>
    ))}
  </ul>
  <p class="mobile-hint">{t('works.mobile-hint')}</p>
</Section>

<div class="ww-backdrop" id="ww-backdrop" aria-hidden="true"></div>

{works.map((w) => (
  <div
    id={`ww-${w.id}`}
    class="ww"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby={`ww-label-${w.id}`}
    aria-describedby={`ww-desc-${w.id}`}
    tabindex="-1"
    data-work-id={w.id}
  >
    <div class="ww-titlebar" data-drag-handle>
      <span class="ww-titlebar__prompt" aria-hidden="true">work@relmy</span>
      <span class="ww-titlebar__sep" aria-hidden="true">:</span>
      <span class="ww-titlebar__path" id={`ww-label-${w.id}`}>{w.path}</span>
      <div class="ww-controls">
        <button class="ww-ctrl ww-ctrl--desktop" data-action="minimize" type="button" aria-label="Minimize">[−]</button>
        <button class="ww-ctrl ww-ctrl--desktop" data-action="fullscreen" type="button" aria-label="Fullscreen">[□]</button>
        <button class="ww-ctrl" data-action="close" type="button" aria-label={t('works.close').replace('{name}', w.name)}>[×]</button>
      </div>
    </div>
    <div class="ww-body" id={`ww-desc-${w.id}`}>
      <div class="ww-img-placeholder" aria-hidden="true">
        <span class="ww-img-placeholder__text" aria-hidden="true">{t('works.placeholder')}</span>
      </div>
      <div class="ww-content">
        <div class="prose-mdx">
            <w.Content />
        </div>
        <div class="ww-links">
          {w.links.map((l) => (
            <a href={l.href} aria-label={l.label} target="_blank" rel="noopener noreferrer" class="ww-link">{l.label}</a>
          ))}
        </div>
        <p class="ww-stack">{w.stack}</p>
      </div>
    </div>
  </div>
))}

<style>
  .works-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .work-item {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.625rem 0;
    min-height: 2.75rem;
    background: none;
    border: none;
    font: inherit;
    color: inherit;
    cursor: pointer;
    text-align: left;
    border-bottom: 1px dashed var(--border);
    transition: border-color 0.15s;
  }

  .work-item:hover { border-color: var(--border-hover); }
  .work-item:hover .work-item__open { opacity: 1; }

  .work-item:focus-visible {
    outline: 2px dashed currentColor;
    outline-offset: 3px;
  }

  .work-item__name { font-size: 0.875rem; }

  .work-item__meta {
    font-size: 0.75rem;
    color: var(--text-subtle);
  }

  .work-item__open {
    font-size: 0.75rem;
    opacity: 0;
    transition: opacity 0.15s;
    white-space: nowrap;
  }

  .mobile-hint {
    display: none;
    margin-top: 1rem;
    font-size: 0.7rem;
    color: var(--text-subtle);
    opacity: 0.6;
    letter-spacing: 0.02em;
  }

  @media (max-width: 560px) {
    .work-item {
      grid-template-columns: 1fr auto;
    }

    .work-item__open { display: none; }

    .mobile-hint { display: block; }
  }

  /* ── Backdrop ── */

  .ww-backdrop {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: rgba(0, 0, 0, 0);
    visibility: hidden;
    pointer-events: none;
    transition: background 0.22s ease, visibility 0s linear 0.22s;
  }

  .ww-backdrop.is-open {
    background: rgba(0, 0, 0, 0.35);
    visibility: visible;
    pointer-events: auto;
    transition: background 0.22s ease, visibility 0s linear 0s;
  }

  /* ── Work window ── */

  .ww {
    position: fixed;
    z-index: 100;
    top: 15vh;
    left: 50%;
    translate: -50% 0;
    scale: 0.97;
    width: min(720px, calc(100vw - 4rem));
    background: var(--ww-bg);
    color: var(--ww-fg);
    border: 1px solid var(--border);
    font-size: 0.8125rem;
    box-shadow: 4px 4px 0 var(--border);
    user-select: none;
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.18s ease, scale 0.18s ease, visibility 0s linear 0.18s;
  }

  .ww.is-open {
    visibility: visible;
    opacity: 1;
    scale: 1;
    transition: opacity 0.18s ease, scale 0.18s ease, visibility 0s linear 0s;
  }

  .ww.is-open.is-dragging {
    transition: none;
  }

  .ww.is-fullscreen {
    top: 0 !important;
    left: 0 !important;
    translate: 0 0 !important;
    transform: none !important;
    width: 100% !important;
    height: 100dvh;
    box-shadow: none;
  }

  .ww.is-fullscreen .ww-titlebar { cursor: default; }
  .ww.is-fullscreen .ww-body { max-height: calc(100dvh - 2.5rem); }

  .ww.is-minimized {
    top: auto !important;
    bottom: 1rem;
    left: 1rem !important;
    translate: 0 0 !important;
    transform: none !important;
    width: min(320px, calc(100vw - 2rem));
    box-shadow: 2px 2px 0 var(--border);
  }

  .ww.is-minimized .ww-body { display: none; }
  .ww.is-minimized .ww-titlebar { cursor: pointer; }

  /* ── Titlebar ── */

  .ww-titlebar {
    display: flex;
    align-items: center;
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid var(--border);
    cursor: grab;
    overflow: hidden;
  }

  .ww-titlebar:active { cursor: grabbing; }

  .ww-titlebar__prompt {
    color: var(--ww-prompt);
    white-space: nowrap;
  }

  .ww-titlebar__sep {
    opacity: 0.4;
    padding-inline: 0.1rem;
  }

  .ww-titlebar__path {
    color: var(--ww-muted);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .ww-controls {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .ww-ctrl {
    background: none;
    border: none;
    font: inherit;
    color: inherit;
    cursor: pointer;
    padding: 0.25rem 0.35rem;
    opacity: 0.6;
    transition: opacity 0.15s;
    min-height: 2.75rem;
    min-width: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ww-ctrl:hover { opacity: 1; }

  .ww-ctrl:focus-visible {
    outline: 2px dashed currentColor;
    outline-offset: 2px;
  }

  /* ── Body ── */

  .ww-body {
    display: flex;
    flex-direction: column;
    user-select: text;
    max-height: calc(85vh - 2.5rem);
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .ww-img-placeholder {
    border-bottom: 1px solid var(--border);
    height: 10rem;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.3;
    flex-shrink: 0;
  }

  .ww-img-placeholder__text {
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  .ww-content {
    padding: 1rem 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .ww-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .ww-link {
    color: inherit;
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.15s;
  }

  .ww-link:hover { opacity: 1; text-decoration: underline; }

  .ww-link:focus-visible {
    outline: 2px dashed currentColor;
    outline-offset: 2px;
  }

  .ww-stack {
    font-size: 0.7rem;
    color: var(--ww-muted);
    letter-spacing: 0.04em;
  }

  @media (max-width: 560px) {
    .ww-ctrl--desktop { display: none; }

    .ww {
      top: auto !important;
      left: 0 !important;
      bottom: 0;
      translate: 0 100% !important;
      scale: 1;
      width: 100%;
      max-height: 85dvh;
      box-shadow: 0 -4px 0 var(--border);
      opacity: 1;
      transition: translate 0.22s ease, visibility 0s linear 0.22s;
    }

    .ww.is-open {
      translate: 0 0 !important;
      scale: 1;
      opacity: 1;
      transition: translate 0.22s ease, visibility 0s linear 0s;
    }

    .ww.is-fullscreen,
    .ww.is-minimized {
      top: auto !important;
      left: 0 !important;
      bottom: 0;
      translate: 0 0 !important;
      transform: none !important;
      width: 100%;
      height: auto;
      max-height: 85dvh;
    }

    .ww-titlebar { cursor: default; }

    .ww-body {
      max-height: calc(85dvh - 2.5rem);
    }
  }
</style>

<script>
  import { initWorkWindows } from '../scripts/work-window';

  initWorkWindows();
  document.addEventListener('astro:page-load', () => {
    (window as any).__wwBound = false;
    initWorkWindows();
  });
</script>
